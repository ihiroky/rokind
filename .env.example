# Google Cloud で Desktop app 用の OAuth Client を作成して、その値を設定します。
# OAuth 情報は .env からのみ読み込みます。画面上での入力・保存はありません。
# この .env はビルド時に埋め込まれます。変更後はアプリの再ビルドが必要です。
GOOGLE_CLIENT_ID=1234567890-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ao_workflow.py 用
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 必要に応じて上書きできます。未設定時は gpt-4o-mini を使います。
OPENAI_MODEL=gpt-4o-mini
# 省略時は https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# Dify DSL の設定に合わせた既定値
OPENAI_TEMPERATURE=0.7
