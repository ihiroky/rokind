{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rokind Reminder",
  "version": "0.1.0",
  "identifier": "dev.rokind.reminder",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rokind Reminder",
        "visible": false,
        "transparent": true,
        "width": 1080,
        "height": 760,
        "minWidth": 920,
        "minHeight": 680,
        "devtools": true,
        "resizable": true,
        "center": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
